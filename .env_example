# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Veliora.AI — Environment Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ─── Application ───
APP_NAME=Veliora.AI
APP_VERSION=1.0.0
DEBUG=true
CORS_ORIGINS=*

# ─── Supabase ───
SUPABASE_URL=""
SUPABASE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# ─── Redis Stack (Local Docker) ───
REDIS_HOST=""
REDIS_PORT=""
REDIS_DB=0

# ─── RabbitMQ (Local Docker) ───
RABBITMQ_URL=""
RABBITMQ_API_URL=""
RABBITMQ_API_USER=guest
RABBITMQ_API_PASS=guest

# ─── Gemini API ───
GEMINI_API_KEY=""
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# ─── Google GenAI SDK Key (used by Redis_chat memory system) ───
GOOGLE_API_KEY=""
# ─── Deepgram (Speech-to-Text) ───
DEEPGRAM_API_KEY=""

# ─── Cartesia (Text-to-Speech) ───
CARTESIA_API_KEY=""
CARTESIA_MODEL=sonic-2

# ─── HuggingFace Serverless API ───
HF_API_TOKEN=""
HF_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# ─── Vector Search ───
VECTOR_TOP_K=50
RERANK_TOP_K=8

# ─── Redis Cache TTLs (seconds) ───
REDIS_CONTEXT_TTL=86400
REDIS_GAME_STATE_TTL=7200
REDIS_CONTEXT_MAX_MESSAGES=50

# ─── RabbitMQ Cleanup ───
CLEANUP_INTERVAL_SEC=60

# ─── Background Workers ───
XP_FLUSH_INTERVAL=60
DIARY_CRON_HOUR=0


GOOGLE_TRANSLATE_API_KEY=""

